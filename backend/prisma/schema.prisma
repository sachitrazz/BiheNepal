// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String      @id @default(uuid())
  phone     String      @unique
  password  String
  role      Role        @default(USER)
  createdAt DateTime    @default(now())
  profile   Profile?
  documents Document[]
  preference Preference?

  @@map("users")
}

model Profile {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName      String
  gender        String
  dob           DateTime
  height        Float?
  caste         String?
  religion      String?
  education     String?
  occupation    String?
  income        Float?
  district      String
  interests     String[]
  bio           String?

  maleMatches   Match[]   @relation("MaleMatches")
  femaleMatches Match[]   @relation("FemaleMatches")

  @@map("profiles")
}

model Document {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType       String
  documentUrl        String
  verificationStatus String   @default("PENDING")

  @@map("documents")
}

model Preference {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredAgeMin    Int?
  preferredAgeMax    Int?
  preferredCaste     String?
  preferredReligion  String?
  preferredEducation String?
  preferredLocation  String?

  @@map("preferences")
}

model Match {
  id              String   @id @default(uuid())
  maleProfileId   String
  femaleProfileId String
  maleProfile     Profile  @relation("MaleMatches", fields: [maleProfileId], references: [id], onDelete: Cascade)
  femaleProfile   Profile  @relation("FemaleMatches", fields: [femaleProfileId], references: [id], onDelete: Cascade)
  matchScore      Float
  status          String   @default("PENDING")

  @@map("matches")
}
